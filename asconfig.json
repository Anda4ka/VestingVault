{
    "targets": {
        "debug": {
            "outFile": "build/VestingVault.wasm",
            "textFile": "build/VestingVault.wat",
            "use": ["abort=src/index/abort"]
        },
        "release": {
            "outFile": "build/VestingVault.wasm",
            "textFile": "build/VestingVault.wat",
            "noAssert": true,
            "optimizeLevel": 3,
            "shrinkLevel": 2,
            "use": ["abort=src/index/abort"]
        },
        "vest-debug": {
            "outFile": "build/VestingToken.wasm",
            "textFile": "build/VestingToken.wat",
            "use": ["abort=src/index_vest/abort"]
        },
        "rev-debug": {
            "outFile": "build/RevenueToken.wasm",
            "textFile": "build/RevenueToken.wat",
            "use": ["abort=src/index_rev/abort"]
        }
    },
    "options": {
        "transform": "@btc-vision/opnet-transform",
        "sourceMap": false,
        "optimizeLevel": 3,
        "shrinkLevel": 1,
        "converge": true,
        "noAssert": false,
        "enable": [
            "sign-extension",
            "mutable-globals",
            "nontrapping-f2i",
            "bulk-memory",
            "simd",
            "reference-types",
            "multi-value"
        ],
        "runtime": "stub",
        "memoryBase": 0,
        "initialMemory": 1,
        "exportStart": "start"
    }
}
